#!/bin/sh
set -eu

modus="benutzer"
case "${1:-}" in
  "") ;;
  --benutzer) modus="benutzer" ;;
  --system) modus="system" ;;
  -h|--hilfe)
    cat <<'EOF'
Gebrauch:
  ./einrichten            benutzerlokal nach ~/.local einrichten
  sudo ./einrichten --system  systemweit nach /usr/local einrichten
EOF
    exit 0
    ;;
  *)
    echo 'Bescheid der Einrichtungsstelle: Unbekannte Angabe.' >&2
    exit 2
    ;;
esac

if [ "$modus" = "system" ]; then
  VORBAU="${PREFIX:-/usr/local}"
else
  VORBAU="${PREFIX:-$HOME/.local}"
fi

BINDIR="$VORBAU/bin"
DATDIR="$VORBAU/share/deutschland-anschnur-muschel"
BEFDIR="$DATDIR/befehle.d"
QUELLORT="$DATDIR/quellort"

hier=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ ! -f "$hier/muschel" ] || [ ! -f "$hier/anschnur-pruefen" ] || [ ! -d "$hier/befehle.d" ]; then
  echo 'Bescheid der Einrichtungsstelle: Quellbestand unvollständig.' >&2
  exit 1
fi

install -d "$BINDIR" "$BEFDIR"
install -m 0755 "$hier/muschel" "$BINDIR/muschel"
install -m 0755 "$hier/anschnur-pruefen" "$BINDIR/anschnur-pruefen"

find "$BEFDIR" -type f -name '*.jsonl' -delete 2>/dev/null || true
for akte in "$hier"/befehle.d/*.jsonl; do
  install -m 0644 "$akte" "$BEFDIR/$(basename "$akte")"
done

printf '%s\n' "$hier" > "$QUELLORT"

echo 'Deutschland Anschnur Muschel wurde eingerichtet.'
echo "  $BINDIR/muschel"
echo "  $BEFDIR"

case ":$PATH:" in
  *":$BINDIR:"*) ;;
  *)
    echo "Hinweis: $BINDIR ist nicht im Suchpfad."
    echo "Für diese Sitzung: PATH=\"$BINDIR:\$PATH\""
    ;;
esac
