#!/bin/sh
set -eu

modus="benutzer"
case "${1:-}" in
  "") ;;
  --benutzer) modus="benutzer" ;;
  --system) modus="system" ;;
  -h|--hilfe)
    cat <<'EOF'
Gebrauch:
  ./einrichten                 muschel benutzerlokal erreichbar machen
  sudo ./einrichten --system   muschel systemweit erreichbar machen
EOF
    exit 0
    ;;
  *)
    echo 'Bescheid der Einrichtungsstelle: Unbekannte Angabe.' >&2
    exit 2
    ;;
esac

hier=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)

if [ ! -f "$hier/muschel" ] || [ ! -f "$hier/anschnur-pruefen" ] || [ ! -d "$hier/befehle.d" ]; then
  echo 'Bescheid der Einrichtungsstelle: Quellbestand unvollständig.' >&2
  exit 1
fi

if [ "$modus" = "system" ]; then
  bindir="${PREFIX:-/usr/local}/bin"
else
  bindir="${PREFIX:-$HOME/.local}/bin"
fi

mkdir -p "$bindir"
ln -sfn "$hier/muschel" "$bindir/muschel"
ln -sfn "$hier/anschnur-pruefen" "$bindir/anschnur-pruefen"

if [ "$modus" = "benutzer" ]; then
  rc="$HOME/.bashrc"
  zeile='export PATH="$HOME/.local/bin:$PATH"'
  if [ -f "$rc" ]; then
    if ! grep -Fxq "$zeile" "$rc"; then
      {
        echo ''
        echo '# Deutschland Anschnur Muschel'
        echo "$zeile"
      } >> "$rc"
    fi
  else
    {
      echo '# Deutschland Anschnur Muschel'
      echo "$zeile"
    } > "$rc"
  fi
fi

echo 'Deutschland Anschnur Muschel wurde erreichbar gemacht.'
echo "  $bindir/muschel"

case ":$PATH:" in
  *":$bindir:"*) ;;
  *) echo "Hinweis: Neue Bash-Sitzung öffnen oder ausführen: PATH=\"$bindir:\$PATH\"" ;;
esac
