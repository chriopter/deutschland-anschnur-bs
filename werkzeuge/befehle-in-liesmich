#!/usr/bin/env python3
"""Schreibt das BEFEHLE-Kapitel der Liesmichakte aus befehle.d/*.jsonl."""

from __future__ import annotations

import html
import json
from collections import OrderedDict
from pathlib import Path

WURZEL = Path(__file__).resolve().parents[1]
LIESMICH = WURZEL / "LIESMICH.txt"
BEFEHLE = WURZEL / "befehle.d"
ANFANG = "<!-- BEFEHLE:ANFANG -->"
ENDE = "<!-- BEFEHLE:ENDE -->"

DATEI_REIHENFOLGE = ["basis", "grundbestand-extra", "hapsmann", "paeckle", "textwesen", "paketwerk", "systemwesen", "netzwesen", "astmann", "hafener"]
GRUPPEN_REIHENFOLGE = ["Muschel", "Grundbestand", "Textwesen", "Paketwerk", "Systemwesen", "Netzwesen", "Entwicklung", "Applikationen"]
GRUPPEN_TITEL = {
    "Muschel": "Muschel (eingebaut)",
}
MUSCHEL_FUNKTIONEN = {"hilfe", "verlassen", "neu_laden"}

def eintraege(datei: Path) -> list[dict]:
    daten = []
    with datei.open(encoding="utf-8") as handle:
        for zeile in handle:
            zeile = zeile.strip()
            if zeile and not zeile.startswith("#"):
                daten.append(json.loads(zeile))
    return daten


def befehlsname(eintrag: dict) -> str:
    return " ".join(eintrag["befehl"])


def hauptbefehl(eintrag: dict) -> str:
    return eintrag["befehl"][0]


def gruppe(eintrag: dict) -> str:
    if eintrag.get("gruppe"):
        return str(eintrag["gruppe"])
    if eintrag.get("typ") == "builtin" and eintrag.get("funktion") in MUSCHEL_FUNKTIONEN:
        return "Muschel"
    return "Grundbestand"


def html_code(wert: str) -> str:
    return f"<code>{html.escape(wert)}</code>"


def html_zelle(wert: str) -> str:
    return html.escape(str(wert)).replace("\n", " ")


def unredlicher_befehl(eintrag: dict) -> str:
    typ = eintrag.get("typ")
    if typ == "exec":
        return Path(eintrag["programm"]).name
    if typ == "builtin":
        return {"cd": "cd", "hilfe": "help", "verlassen": "exit", "neu_laden": "source"}.get(
            str(eintrag.get("funktion", "")), "muschel"
        )
    return ""


def unredliche_befehle(daten: list[dict]) -> str:
    werte = []
    gesehen = set()
    for eintrag in daten:
        wert = unredlicher_befehl(eintrag)
        if wert and wert not in gesehen:
            gesehen.add(wert)
            werte.append(wert)
    return ", ".join(werte)


def varianten_liste(daten: list[dict]) -> list[str]:
    zeilen = ["<ul>"]
    for eintrag in daten:
        zeilen.append(
            f"<li>{html_code(befehlsname(eintrag))} — {html_zelle(eintrag.get('beschreibung', 'dienstlich erfasst'))}</li>"
        )
    zeilen.append("</ul>")
    return zeilen


def befehlszellen(name: str, daten: list[dict]) -> list[str]:
    return [
        "<td>",
        "<details>",
        f"<summary>{html_code(name)}</summary>",
        *varianten_liste(daten),
        "</details>",
        "</td>",
        f"<td>{html_code(unredliche_befehle(daten))}</td>",
    ]


def gruppierte_eintraege() -> OrderedDict[str, OrderedDict[str, list[dict]]]:
    dateien = {datei.stem: datei for datei in BEFEHLE.glob("*.jsonl")}
    namen = [name for name in DATEI_REIHENFOLGE if name in dateien]
    namen.extend(sorted(name for name in dateien if name not in namen))

    gruppen: OrderedDict[str, OrderedDict[str, list[dict]]] = OrderedDict(
        (name, OrderedDict()) for name in GRUPPEN_REIHENFOLGE
    )
    for name in namen:
        for eintrag in eintraege(dateien[name]):
            gruppen.setdefault(gruppe(eintrag), OrderedDict()).setdefault(hauptbefehl(eintrag), []).append(eintrag)
    return OrderedDict((name, daten) for name, daten in gruppen.items() if daten)


def gruppenzeilen(gruppenname: str, hauptgruppen: OrderedDict[str, list[dict]]) -> list[str]:
    zeilen: list[str] = []
    span = len(hauptgruppen)
    erste = True
    for name, daten in hauptgruppen.items():
        zellen = ["<tr>"]
        if erste:
            titel = GRUPPEN_TITEL.get(gruppenname, gruppenname)
            zellen.append(f"<td rowspan=\"{span}\"><strong>{html_zelle(titel)}</strong></td>")
            erste = False
        zellen.extend(befehlszellen(name, daten))
        zellen.append("</tr>")
        zeilen.extend(zellen)
    return zeilen


def befehlstabelle(gruppen: OrderedDict[str, OrderedDict[str, list[dict]]]) -> list[str]:
    zeilen = [
        "<table>",
        "<thead>",
        "<tr><th>Befehlskategorie</th><th>Befehl</th><th>Angelsächsischer unredlicher Befehl</th></tr>",
        "</thead>",
        "<tbody>",
    ]
    for gruppenname, hauptgruppen in gruppen.items():
        zeilen.extend(gruppenzeilen(gruppenname, hauptgruppen))
    zeilen.extend(["</tbody>", "</table>", ""])
    return zeilen


def befehlsblock() -> str:
    teile = [ANFANG, ""]
    teile.extend(befehlstabelle(gruppierte_eintraege()))
    teile.append(ENDE)
    return "\n".join(teile)


def main() -> int:
    text = LIESMICH.read_text(encoding="utf-8")
    block = befehlsblock()
    if ANFANG in text and ENDE in text:
        davor, rest = text.split(ANFANG, 1)
        _, danach = rest.split(ENDE, 1)
        neu = davor.rstrip() + "\n\n" + block + danach
    else:
        marker = "## BEFEHLE\n"
        davor, _ = text.split(marker, 1)
        neu = davor + marker + "\n" + block + "\n"
    LIESMICH.write_text(neu, encoding="utf-8")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
