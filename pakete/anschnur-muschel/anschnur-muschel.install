post_install() {
  if ! grep -qx '/usr/bin/muschel' /etc/shells 2>/dev/null; then
    echo '/usr/bin/muschel' >> /etc/shells
  fi

  if command -v chsh >/dev/null 2>&1; then
    chsh -s /usr/bin/muschel root >/dev/null 2>&1 || true
  elif command -v usermod >/dev/null 2>&1; then
    usermod -s /usr/bin/muschel root >/dev/null 2>&1 || true
  fi
}

post_upgrade() {
  post_install
}

post_remove() {
  if [ -f /etc/shells ]; then
    sed -i '\#^/usr/bin/muschel$#d' /etc/shells
  fi
}
