#!/bin/sh
set -eu

modus="benutzer"
case "${1:-}" in
  "") ;;
  --benutzer) modus="benutzer" ;;
  --system) modus="system" ;;
  -h|--hilfe)
    cat <<'EOF'
Gebrauch:
  ./entfernen                 benutzerlokale Erreichbarkeit entfernen
  sudo ./entfernen --system   systemweite Erreichbarkeit entfernen
EOF
    exit 0
    ;;
  *)
    echo 'Bescheid der Entfernungsstelle: Unbekannte Angabe.' >&2
    exit 2
    ;;
esac

if [ "$modus" = "system" ]; then
  bindir="${PREFIX:-/usr/local}/bin"
else
  bindir="${PREFIX:-$HOME/.local}/bin"
fi

rm -f "$bindir/muschel" "$bindir/anschnur-pruefen"

echo 'Deutschland Anschnur Muschel wurde aus dem Befehlsweg entfernt.'
