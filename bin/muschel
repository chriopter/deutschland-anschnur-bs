#!/usr/bin/env python3
"""Deutschland Anschnur Muschel: tabellengetriebene Befehlsuebersetzung."""

from __future__ import annotations

import json
import os
import shlex
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Callable

def befehlsorte() -> list[Path]:
    vorgabe = os.environ.get("ANSCHNUR_BEFEHLE")
    if vorgabe:
        return [Path(vorgabe)]
    rohorte = [
        Path(__file__).resolve().parent.parent / "befehle.d",
        Path(__file__).resolve().parent / "befehle.d",
        Path(__file__).resolve().parent.parent / "share" / "deutschland-anschnur-muschel" / "befehle.d",
        Path("/usr/local/share/deutschland-anschnur-muschel/befehle.d"),
        Path("/usr/share/deutschland-anschnur-muschel/befehle.d"),
        Path("/usr/share/anschnur/befehle.d"),
    ]
    ergebnis: list[Path] = []
    gesehen: set[Path] = set()
    for ort in rohorte:
        if ort is None:
            continue
        schluessel = ort.resolve() if ort.exists() else ort.absolute()
        if schluessel in gesehen:
            continue
        gesehen.add(schluessel)
        ergebnis.append(ort)
    return ergebnis

ERLAUBTE_TYPEN = {"exec", "builtin", "alias"}
ERLAUBTER_REST = {"verbieten", "anhaengen", "ein_wert"}
EINGEBAUT = {"hilfe", "verlassen", "cd", "neu_laden"}
GRUEN = "\033[32m"
RESET = "\033[0m"


def gruen(text: str) -> str:
    if sys.stdout.isatty():
        return f"{GRUEN}{text}{RESET}"
    return text


def git_text(quelle: Path, *args: str, timeout: int = 3) -> str | None:
    try:
        vorgang = subprocess.run(
            ["git", "-C", str(quelle), *args],
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            timeout=timeout,
            check=False,
        )
    except (OSError, subprocess.TimeoutExpired):
        return None
    if vorgang.returncode != 0:
        return None
    return vorgang.stdout.strip()


def git_version(quelle: Path, stand: str) -> str:
    kurz = git_text(quelle, "rev-parse", "--short", stand) or "unbekannt"
    datum = git_text(quelle, "log", "-1", "--format=%cd", "--date=short", stand) or "unbekannt"
    return f"{kurz} vom {datum}"


class Befehlsfehler(Exception):
    pass


class Muschel:
    def __init__(self) -> None:
        self.befehle: dict[tuple[str, ...], dict] = {}
        self.lade_befehle()

    def lade_befehle(self) -> None:
        geladen: dict[tuple[str, ...], dict] = {}
        dateien: list[Path] = []
        for ort in befehlsorte():
            if ort.is_dir():
                dateien.extend(sorted(ort.glob("*.jsonl")))
        if not dateien:
            raise Befehlsfehler("Keine Befehlsakten gefunden.")

        for datei in dateien:
            with datei.open(encoding="utf-8") as handle:
                for nummer, zeile in enumerate(handle, 1):
                    zeile = zeile.strip()
                    if not zeile or zeile.startswith("#"):
                        continue
                    try:
                        eintrag = json.loads(zeile)
                    except json.JSONDecodeError as fehler:
                        raise Befehlsfehler(f"{datei}:{nummer}: ungueltige Befehlsakte: {fehler}") from fehler
                    self.pruefe_eintrag(eintrag, datei, nummer)
                    schluessel = tuple(eintrag["befehl"])
                    if schluessel in geladen:
                        raise Befehlsfehler(f"{datei}:{nummer}: doppelter Befehl: {' '.join(schluessel)}")
                    geladen[schluessel] = eintrag
        self.befehle = geladen

    @staticmethod
    def pruefe_eintrag(eintrag: dict, datei: Path, nummer: int) -> None:
        ort = f"{datei}:{nummer}"
        befehl = eintrag.get("befehl")
        if not isinstance(befehl, list) or not befehl or not all(isinstance(wort, str) and wort for wort in befehl):
            raise Befehlsfehler(f"{ort}: Befehl muss nichtleere Wortliste sein")
        gruppe = eintrag.get("gruppe", "Grundbestand")
        if not isinstance(gruppe, str) or not gruppe:
            raise Befehlsfehler(f"{ort}: Gruppe muss Textwert sein")
        typ = eintrag.get("typ")
        if typ not in ERLAUBTE_TYPEN:
            raise Befehlsfehler(f"{ort}: unzulaessiger Typ: {typ}")
        rest = eintrag.get("rest", "verbieten")
        if rest not in ERLAUBTER_REST:
            raise Befehlsfehler(f"{ort}: unzulaessige Restordnung: {rest}")
        if typ == "exec":
            programm = eintrag.get("programm")
            if not isinstance(programm, str) or not programm.startswith("/"):
                raise Befehlsfehler(f"{ort}: Programm muss absoluter Pfad sein")
            argumente = eintrag.get("argumente", [])
            if not isinstance(argumente, list) or not all(isinstance(wert, str) for wert in argumente):
                raise Befehlsfehler(f"{ort}: Argumente muessen Liste aus Textwerten sein")
            optionen = eintrag.get("optionen", {})
            if not isinstance(optionen, dict):
                raise Befehlsfehler(f"{ort}: Optionen muessen Zuordnung sein")
        elif typ == "builtin":
            funktion = eintrag.get("funktion")
            if funktion not in EINGEBAUT:
                raise Befehlsfehler(f"{ort}: unbekannte eingebaute Funktion: {funktion}")
        elif typ == "alias":
            ziel = eintrag.get("ziel")
            if not isinstance(ziel, list) or not ziel:
                raise Befehlsfehler(f"{ort}: Aliasziel muss Wortliste sein")

    def finde(self, teile: list[str]) -> tuple[dict | None, list[str]]:
        for laenge in range(len(teile), 0, -1):
            schluessel = tuple(teile[:laenge])
            if schluessel in self.befehle:
                return self.befehle[schluessel], teile[laenge:]
        return None, teile

    def hilfe(self) -> None:
        print("Zugelassene Amtsbefehle:")
        for schluessel, eintrag in sorted(self.befehle.items()):
            beschreibung = eintrag.get("beschreibung", "dienstlich erfasst")
            print(f"  {' '.join(schluessel):32} - {beschreibung}")

    def melde_nicht_erlaubt(self, befehl: str) -> None:
        print(f"Bescheid der Muschelbehörde: Der Befehl \"{befehl}\" ist nicht erlaubt.")
        fundstelle = self.finde_programm(befehl)
        if fundstelle:
            print(f"Sachstand: \"{befehl}\" ist im System vorhanden ({fundstelle}), aber dienstlich noch nicht freigegeben.")
        else:
            print(f"Sachstand: \"{befehl}\" konnte im System nicht festgestellt werden.")
        print("Hinweis: Bitte reichen Sie einen Antrag auf Befehlsverdeutschung ein.")

    @staticmethod
    def finde_programm(name: str) -> str | None:
        for ordner in os.environ.get("PATH", "").split(os.pathsep):
            if not ordner:
                continue
            kandidat = Path(ordner) / name
            if kandidat.is_file() and os.access(kandidat, os.X_OK):
                return str(kandidat)
        return None

    @staticmethod
    def bereite_rest(eintrag: dict, rest: list[str]) -> list[str] | None:
        ordnung = eintrag.get("rest", "verbieten")
        if ordnung == "verbieten":
            if rest:
                print("Bescheid der Muschelbehörde: Weitere Angaben sind hier nicht zugelassen.")
                return None
            return []
        if ordnung == "ein_wert":
            if len(rest) != 1:
                print("Bescheid der Muschelbehörde: Genau eine weitere Angabe ist erforderlich.")
                return None
            return rest
        return rest

    @staticmethod
    def uebersetze_optionen(eintrag: dict, werte: list[str]) -> list[str]:
        optionen = eintrag.get("optionen", {})
        ergebnis: list[str] = []
        for wert in werte:
            if wert in optionen:
                ziel = optionen[wert]
                if isinstance(ziel, str):
                    ergebnis.append(ziel)
                elif isinstance(ziel, list):
                    ergebnis.extend(ziel)
                else:
                    ergebnis.append(wert)
            elif "=" in wert:
                name, inhalt = wert.split("=", 1)
                ziel = optionen.get(name)
                if isinstance(ziel, str):
                    ergebnis.append(f"{ziel}={inhalt}")
                else:
                    ergebnis.append(wert)
            else:
                ergebnis.append(wert)
        return ergebnis

    def fuehre_aus(self, eintrag: dict, rest: list[str]) -> None:
        typ = eintrag["typ"]
        if typ == "alias":
            ziel = list(eintrag["ziel"]) + rest
            self.verarbeite_teile(ziel)
            return

        if typ == "builtin":
            self.fuehre_builtin(eintrag, rest)
            return

        restwerte = self.bereite_rest(eintrag, rest)
        if restwerte is None:
            return
        restwerte = self.uebersetze_optionen(eintrag, restwerte)
        befehl = [eintrag["programm"], *eintrag.get("argumente", []), *restwerte]
        try:
            subprocess.run(befehl, check=False)
        except FileNotFoundError:
            print(f"Bescheid der Muschelbehörde: Ausführungsbestand nicht vorhanden: {eintrag['programm']}")

    def fuehre_builtin(self, eintrag: dict, rest: list[str]) -> None:
        funktion = eintrag["funktion"]
        restwerte = self.bereite_rest(eintrag, rest)
        if restwerte is None:
            return
        if funktion == "hilfe":
            self.hilfe()
        elif funktion == "verlassen":
            print("Muschel wird ordnungsgemäß geschlossen.")
            raise SystemExit(0)
        elif funktion == "cd":
            ziel = restwerte[0]
            try:
                os.chdir(os.path.expanduser(ziel))
                print(os.getcwd())
            except OSError as fehler:
                print(f"Bescheid der Muschelbehörde: Ortswechsel abgelehnt: {fehler}")
        elif funktion == "neu_laden":
            self.lade_befehle()
            print("Befehlsakten neu geladen.")

    def verarbeite_teile(self, teile: list[str]) -> None:
        if not teile:
            return
        eintrag, rest = self.finde(teile)
        if eintrag is None:
            self.melde_nicht_erlaubt(teile[0])
            return
        self.fuehre_aus(eintrag, rest)

    def verarbeite_zeile(self, zeile: str) -> None:
        if not zeile.strip():
            return
        try:
            teile = shlex.split(zeile)
        except ValueError as fehler:
            print(f"Bescheid der Muschelbehörde: Eingabe nicht lesbar: {fehler}")
            return
        self.verarbeite_teile(teile)

    @staticmethod
    def quellort() -> Path | None:
        quelle = Path(__file__).resolve().parent
        if not (quelle / ".git").exists() and (quelle.parent / ".git").exists():
            quelle = quelle.parent
        if not (quelle / ".git").exists():
            return None
        innen = git_text(quelle, "rev-parse", "--is-inside-work-tree")
        if innen != "true":
            return None
        return quelle

    def pruefe_aktualisierung(self, frage: Callable[[str], str] = input) -> None:
        if os.environ.get("ANSCHNUR_AKTUALISIERUNG", "1") in {"0", "nein", "aus"}:
            return
        quelle = self.quellort()
        if quelle is None:
            return

        derzeit = git_version(quelle, "HEAD")
        try:
            subprocess.run(
                ["git", "-C", str(quelle), "fetch", "--quiet", "--prune"],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                timeout=10,
                check=False,
            )
        except (OSError, subprocess.TimeoutExpired):
            print(f"Muschelstand: {gruen('nicht prüfbar')} — derzeit {derzeit}")
            return

        stand_text = git_text(quelle, "rev-list", "--left-right", "--count", "HEAD...@{u}")
        if not stand_text:
            print(f"Muschelstand: {gruen('ohne Gegenstelle')} — {derzeit}")
            return
        teile = stand_text.split()
        if len(teile) != 2:
            return
        try:
            rueckstand = int(teile[1])
        except ValueError:
            return
        if rueckstand <= 0:
            print(f"Muschelstand: {gruen('aktuell')} — {derzeit}")
            return

        bereit = git_version(quelle, "@{u}")
        print(f"Muschelstand: {gruen('Erneuerung verfügbar')}")
        print(f"Derzeit: {derzeit}")
        print(f"Bereit:  {bereit}")
        antwort = frage("Jetzt beziehen? [j/N] ").strip().lower()
        if antwort not in {"j", "ja", "y", "yes"}:
            print("Aktualisierung zurückgestellt.")
            return

        vorgang = subprocess.run(["git", "-C", str(quelle), "pull", "--ff-only"], check=False)
        if vorgang.returncode == 0:
            self.lade_befehle()
            print(f"Aktualisierung bezogen: {bereit}. Bei Muscheländerungen bitte neu starten.")
        else:
            print("Bescheid der Muschelbehörde: Aktualisierung konnte nicht bezogen werden.")

    def bashrc_text(self) -> str:
        muschelpfad = shlex.quote(str(Path(__file__).resolve()))
        haupt = sorted({schluessel[0] for schluessel in self.befehle if schluessel})
        befehlszeilen = [" ".join(schluessel) for schluessel in sorted(self.befehle)]

        zeilen = [
            "# Deutschland Anschnur Muschel: Bash-Betriebsraum",
            "[ -r ~/.bashrc ] && . ~/.bashrc",
            f"__ANSCHNUR_MUSCHEL={muschelpfad}",
            "PS1='muschel \\w > '",
            "hilfe() { \"$__ANSCHNUR_MUSCHEL\" hilfe \"$@\"; }",
            "verlassen() { exit; }",
            "__anschnur_befehle=(",
        ]
        zeilen.extend(f"  {shlex.quote(zeile)}" for zeile in befehlszeilen)
        zeilen.extend([
            ")",
            "__anschnur_vervollstaendige() {",
            "  local cur=\"${COMP_WORDS[COMP_CWORD]}\"",
            "  local befehl=\"${COMP_WORDS[0]}\"",
            "  local zeile kandidat passt i",
            "  local -a teile antwort",
            "  for zeile in \"${__anschnur_befehle[@]}\"; do",
            "    read -r -a teile <<< \"$zeile\"",
            "    [ \"${teile[0]}\" = \"$befehl\" ] || continue",
            "    passt=1",
            "    for ((i=1; i<COMP_CWORD; i++)); do",
            "      [ \"${teile[i]}\" = \"${COMP_WORDS[i]}\" ] || { passt=0; break; }",
            "    done",
            "    [ \"$passt\" = 1 ] || continue",
            "    kandidat=\"${teile[COMP_CWORD]}\"",
            "    [ -n \"$kandidat\" ] || continue",
            "    [[ \"$kandidat\" == \"$cur\"* ]] && [[ \" ${antwort[*]} \" != *\" $kandidat \"* ]] && antwort+=(\"$kandidat\")",
            "  done",
            "  COMPREPLY=($(compgen -W \"${antwort[*]}\" -- \"$cur\"))",
            "}",
        ])
        for name in haupt:
            if name in {"hilfe", "verlassen"}:
                continue
            sicher = shlex.quote(name)
            if name == "verzeichnis":
                zeilen.append(
                    "verzeichnis() { if [ \"$1\" = wechsel ]; then shift; cd \"$@\"; "
                    "else \"$__ANSCHNUR_MUSCHEL\" verzeichnis \"$@\"; fi; }"
                )
            else:
                zeilen.append(f"{name}() {{ \"$__ANSCHNUR_MUSCHEL\" {sicher} \"$@\"; }}")
            zeilen.append(f"complete -o bashdefault -o default -F __anschnur_vervollstaendige {sicher}")
        return "\n".join(zeilen) + "\n"

    def starte_bash(self) -> None:
        with tempfile.NamedTemporaryFile("w", encoding="utf-8", delete=False) as datei:
            datei.write(self.bashrc_text())
            rc = datei.name
        try:
            bash = "/usr/bin/bash" if Path("/usr/bin/bash").exists() else "/bin/bash"
            subprocess.run([bash, "--rcfile", rc, "-i"], check=False)
        finally:
            try:
                os.unlink(rc)
            except OSError:
                pass

    def schleife(self) -> None:
        if sys.stdin.isatty():
            self.pruefe_aktualisierung()
            print("Deutschland Anschnur Muschel")
            print("Bash-Betriebsraum aktiv. 'hilfe' zeigt Amtsbefehle, 'verlassen' schließt.")
            self.starte_bash()
            return
        for zeile in sys.stdin:
            self.verarbeite_zeile(zeile)


def main() -> int:
    try:
        muschel = Muschel()
        if len(sys.argv) > 1:
            muschel.verarbeite_zeile(" ".join(shlex.quote(wert) for wert in sys.argv[1:]))
        else:
            muschel.schleife()
        return 0
    except Befehlsfehler as fehler:
        print(f"Bescheid der Muschelbehörde: {fehler}", file=sys.stderr)
        return 2


if __name__ == "__main__":
    raise SystemExit(main())
